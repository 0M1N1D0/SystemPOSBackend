# Base de datos PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB_NAME

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=systemPos

# JWT
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_PIN_TOKEN_EXPIRE_MINUTES=480
